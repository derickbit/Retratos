  m_Script: {fileID: 11500000, guid: fe227ce910f250841b7879d1984a2c0d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroTalker
  frasesDaCutscene:
  - "Ca\xE7ador: \"Finalmente um descanso... Achei que a gente nunca ia conseguir
    bater as agendas.\""
  - 'Amigo: "Nem me fala. A vida ta uma correria, ainda mais pra um cara suuuuper
    ocupado como tu"'
  - "Ca\xE7ador: \"E eu tava era fugindo de ti... ainda bem que n\xE3o tem nenhuma
    montanha por aqui, hahaha.\""
  - "Amigo: \"Muito engra\xE7ado. Vai ca\xE7ar e n\xE3o me enche. Teu rifle ta ali
    na tua barraca\""
